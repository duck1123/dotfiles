# Switch both home-manager and NixOS
def "nur switch" [] {
    nur switch-home
    nur switch-os
}

# Update home-manager from flake
def "nur switch-home" [] {
    let ts = (date now | format date '%s')
    ^home-manager switch --flake . -b $"backup.($ts)" --show-trace
}

# Update NixOS from flake (builds and activates immediately)
def "nur switch-os" [] {
    try {
        ^sudo nixos-rebuild switch --flake . --show-trace
    } catch {|_e|
        print "\n=== systemd journal (last 50 lines) ==="
        ^journalctl -xe --no-pager -n 50
        exit $env.LAST_EXIT_CODE
    }
}

# Build NixOS config and set as boot default (activates on reboot)
def "nur boot-os" [] {
    ^sudo nixos-rebuild boot --flake . --show-trace
}

# Apply NixOS config on a fresh install where nix-command is not yet enabled
def "nur bootstrap-os" [] {
    with-env { NIX_CONFIG: "experimental-features = nix-command flakes" } {
        ^nh os boot .
    }
}

